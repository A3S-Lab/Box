{
  "name": "@a3s-lab/box",
  "version": "3.0.12",
  "description": "Local-first TypeScript SDK for A3S Box with E2B-like APIs",
  "type": "module",
  "sideEffects": false,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A3S-Lab/Box.git",
    "directory": "sdk/typescript"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./code-interpreter": {
      "types": "./dist/code-interpreter.d.ts",
      "import": "./dist/code-interpreter.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.tests.json && node tests/exports.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.19.9",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
